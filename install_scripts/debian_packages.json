{
  "tools": {
    "symlink": {
      "src_root" : "~/dotfiles",
      "dest_root" : "~",
      "backup_dir" : "/tmp/backup"
    }
  },
  "packages": {
    "apt": [
      { "package" : "fzf" },
      { "package" : "ripgrep" },
      { "package" : "tmux" }
    ],
    "symlink": [
      { "src" : "config/fish", "dest" : ".config/fish" },
      { "src" : "config/tmux", "dest" : ".config/tmux" },
      { "src" : "tmux.conf", "dest": ".tmux.conf" }
    ],
    "git": [
      { "repo": "https://github.com/jamesjjx/nvim.git", "dir": "~/.config/nvim" },
      { "repo": "https://github.com/tmux-plugins/tpm", "dir": "~/.tmux/plugins/tpm" }
    ],
    "cmd" : [
      { "cmd" : "~/dotfiles/install_scripts/install_neovim.sh" }
    ]
  }
}
